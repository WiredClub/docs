<style>
	#page-reader {
		display: flex;
		align-items: center;
		gap: 6px;
		font-family: inherit;
		position: relative;
		z-index: 10;
		margin-bottom: 1.5rem;
	}

	#page-reader * {
	margin: 0;
	}
	svg {
		min-width: 16px;
	}

	#pr-toggle {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 5px 12px 5px 9px;
		border: 1px solid var(--sl-color-gray-5, rgba(255,255,255,0.15));
		border-radius: 6px;
		background: var(--sl-color-bg-sidebar, transparent);
		color: var(--sl-color-text, #cdd6f4);
		font-size: 0.78rem;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.15s, border-color 0.15s;
		white-space: nowrap;
	}

	#pr-toggle:hover {
		background: var(--sl-color-gray-6, rgba(255,255,255,0.08));
		border-color: var(--sl-color-accent, #7c3aed);
	}

	#pr-toggle.reading {
		border-color: var(--sl-color-accent, #7c3aed);
		/* color: var(--sl-color-accent, #7c3aed); */
	}

	/* :global(header) {
		anchor-name: --header;
	} */
	#page-reader:has(#pr-toggle.reading) {
		position: sticky;
		top: 120px;
		/* position: fixed;
		position-anchor: --header;
		top: calc(anchor(bottom) + 10px); */
		/*
		Não funcionou por que precisa ser "position: absolute" (não segue o header)
		ou "position: fixed" (desocupa o espaço no DOM). Precisava que continuasse
		sendo "position: sticky".
		*/
	}

	#pr-controls {
		display: none;
		align-items: center;
		gap: 4px;
		padding: 4px 8px;
		border: 1px solid var(--sl-color-gray-5, rgba(255,255,255,0.12));
		border-radius: 6px;
		background: var(--sl-color-bg-sidebar, transparent);
	}

	#pr-controls.visible {
		display: flex;
	}

	#pr-stop, #pr-switch-voice {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 3px;
		border: none;
		background: transparent;
		color: var(--sl-color-text-accent, #f38ba8);
		cursor: pointer;
		border-radius: 4px;
		transition: background 0.12s;
	}

	#pr-stop:hover, #pr-switch-voice:hover {
		background: rgba(243, 139, 168, 0.12);
	}

	.pr-divider {
		width: 1px;
		height: 16px;
		background: var(--sl-color-gray-5, rgba(255,255,255,0.12));
		margin: 0 2px;
	}

	.pr-field {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		color: var(--sl-color-gray-2, #a6adc8);
		font-size: 0.72rem;
	}

	.pr-field input[type="range"] {
		-webkit-appearance: none;
		appearance: none;
		max-width: 60px;
		width: 100%;
		height: 3px;
		border-radius: 2px;
		background: var(--sl-color-gray-5, rgba(255,255,255,0.15));
		outline: none;
		cursor: pointer;
	}

	.pr-field input[type="range"]::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--sl-color-accent, #7c3aed);
		cursor: pointer;
	}

	.pr-field input[type="range"]::-moz-range-thumb {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--sl-color-accent, #7c3aed);
		cursor: pointer;
		border: none;
	}

	.pr-field span {
		min-width: 22px;
		font-variant-numeric: tabular-nums;
	}
</style>
<style is:global>
/* Highlight styles injected into the article */
.pr-highlight-block {
	outline-style: solid !important;
	outline-width: 2px !important;
	outline-color: var(--sl-color-accent, #7c3aed);
	outline-offset: 3px;
	border-radius: 4px;
	background-color: color-mix(in srgb, var(--sl-color-accent, #7c3aed) 8%, transparent);
	scroll-margin-top: 100px;

	animation: pr-pulse 1.6s ease-in-out infinite;
}

@keyframes pr-pulse {
	0% {
		outline-color: color-mix(in srgb, var(--sl-color-accent, #7c3aed) 40%, transparent) !important;
		background: color-mix(in srgb, var(--sl-color-accent, #7c3aed) 6%, transparent) !important;
	}

	50% {
		outline-color: color-mix(in srgb, var(--sl-color-accent, #7c3aed) 100%, transparent) !important;
		background: color-mix(in srgb, var(--sl-color-accent, #7c3aed) 14%, transparent) !important;
	}

	100% {
		outline-color: color-mix(in srgb, var(--sl-color-accent, #7c3aed) 40%, transparent) !important;
		background: color-mix(in srgb, var(--sl-color-accent, #7c3aed) 6%, transparent) !important;
	}
}
</style>

<script>
	(() => {
		const synth = window.speechSynthesis;
		if (!synth) return;

		const toggle = document.getElementById('pr-toggle') as HTMLButtonElement | null;
		const label = document.getElementById('pr-label');
		const iconPlay = document.getElementById('pr-icon-play');
		const iconPause = document.getElementById('pr-icon-pause');
		const controls = document.getElementById('pr-controls');
		const stopBtn = document.getElementById('pr-stop');
		const rateInput = document.getElementById('pr-rate') as HTMLInputElement | null;
		const pitchInput = document.getElementById('pr-pitch') as HTMLInputElement | null;
		const rateVal = document.getElementById('pr-rate-val');
		const pitchVal = document.getElementById('pr-pitch-val');
		const switchVoiceBtn = document.getElementById('pr-switch-voice');

		const voices = [] as SpeechSynthesisVoice[]
		const VOICE_LANG = document.documentElement.lang || 'pt-BR'
		const PREFERED_VOICE = 'Google português do Brasil'
		let currentVoiceIndex = 0

		if (toggle) {
			toggle.disabled = false;
			toggle.setAttribute('aria-label', 'Iniciar leitura');
			toggle.setAttribute('title', 'Iniciar leitura');
		}

		// Selectors for readable blocks (Starlight article content)
		const BLOCK_SELECTORS = 'h1, h2, h3, h4, h5, h6, p, li';
		const ARTICLE_SELECTOR = '.sl-markdown-content, article, main [data-content]';

		let blocks = [] as Element[];
		let currentIndex = 0;
		let isPlaying = false;
		let isPaused = false;

		function populateVoiceList() {
			const vcs = synth.getVoices();

			voices.length = 0
			for (const voice of vcs) {
				if (voice.lang.toLowerCase().replace(/[^a-z]/g, '') === VOICE_LANG.toLowerCase().replace(/[^a-z]/g, ''))
				voices.push(voice)
			}
			// alert(`Vozes encontradas: ${vcs.map(v => `${v.name} (${v.lang})`).join(', ')}`)

			const savedVoice = sessionStorage.getItem('voice')
			if (savedVoice !== null)
				currentVoiceIndex = parseInt(savedVoice)
			else
				currentVoiceIndex = voices.findIndex(v => v.name === PREFERED_VOICE)
			currentVoiceIndex = currentVoiceIndex >= 0 ? currentVoiceIndex : 0
		}
		populateVoiceList();
		if (synth.onvoiceschanged !== undefined) {
			synth.onvoiceschanged = populateVoiceList;
		}

		function getArticle() {
			return document.querySelector(ARTICLE_SELECTOR) || document.querySelector('main');
		}

		function collectBlocks() {
			const article = getArticle();
			if (!article) return [];
			return Array.from(article.querySelectorAll(BLOCK_SELECTORS)).filter(
				el => el.textContent.trim().length > 0
			);
		}

		function clearHighlight() {
			document.querySelectorAll('.pr-highlight-block').forEach(el => {
				el.classList.remove('pr-highlight-block');
			});
		}

		function highlightBlock(el: Element | null) {
			clearHighlight();
			if (!el) return;
			el.classList.add('pr-highlight-block');
			el.scrollIntoView({ behavior: 'smooth', block: 'center' });
		}

		function speakBlock(index: number) {
			if (index >= blocks.length) {
				stop();
				return;
			}
			currentIndex = index;
			const el = blocks[index];
			highlightBlock(el);

			const text = el.textContent.trim();
			if (!text) {
				speakBlock(index + 1);
				return;
			}

			const utt = new SpeechSynthesisUtterance(text);
			utt.rate = parseFloat(rateInput?.value || '1');
			utt.pitch = parseFloat(pitchInput?.value || '1');
			utt.voice = voices[currentVoiceIndex] || null;
			utt.lang = VOICE_LANG;

			utt.onend = () => {
				if (isPlaying && !isPaused) {
					speakBlock(index + 1);
				}
			};

			utt.onerror = (e) => {
				if (e.error !== 'interrupted') speakBlock(index + 1);
			};

			synth.cancel();
			synth.speak(utt);
		}

		function start() {
			blocks = collectBlocks();
			if (blocks.length === 0) return;
			isPlaying = true;
			isPaused = false;
			setPlayingUI(true);
			speakBlock(currentIndex);
		}

		function pause() {
			isPaused = true;
			synth.pause();
			setPlayingUI(false, true);
		}

		function resume() {
			isPaused = false;
			if (/Android/i.test(navigator.userAgent)) {
				// Obs: desde 2014 o `pause` funciona como o `cancel` no Android
				// https://github.com/mdn/browser-compat-data/issues/4500
				speakBlock(currentIndex);
			} else {
				synth.resume();
			}
			setPlayingUI(true);
		}

		function stop() {
			isPlaying = false;
			isPaused = false;
			currentIndex = 0;
			synth.cancel();
			clearHighlight();
			setPlayingUI(false);
			controls?.classList.remove('visible');
		}

		function setPlayingUI(playing: boolean, paused = false) {
			if (playing) {
				toggle?.classList.add('reading');
				if (iconPlay) iconPlay.style.display = 'none';
				if (iconPause) iconPause.style.display = '';
				if (label) label.textContent = 'Pausar';
				controls?.classList.add('visible');
			} else if (paused) {
				toggle?.classList.add('reading');
				if (iconPlay) iconPlay.style.display = '';
				if (iconPause) iconPause.style.display = 'none';
				if (label) label.textContent = 'Retomar';
				controls?.classList.add('visible');
			} else {
				toggle?.classList.remove('reading');
				if (iconPlay) iconPlay.style.display = '';
				if (iconPause) iconPause.style.display = 'none';
				if (label) label.textContent = 'Ouvir página';
			}
		}

	function handleRateChange() {
		if (!rateVal || !rateInput) return

		const value = parseFloat(rateInput.value)
		rateVal.textContent = value.toFixed(1).replace('.0','') + '×';

		sessionStorage.setItem('rate', value+'')
	}

	function handlePitchChange() {
		if (!pitchVal || !pitchInput) return

		const value = parseFloat(pitchInput.value)
		pitchVal.textContent = value.toFixed(1).replace('.0','') + '×';

		sessionStorage.setItem('pitch', value+'')
	}

		// Toggle play/pause
		toggle?.addEventListener('click', () => {
			if (!isPlaying && !isPaused) {
				start();
			} else if (isPlaying && !isPaused) {
				pause();
			} else if (isPaused) {
				resume();
			}
		});

		stopBtn?.addEventListener('click', stop);

		rateInput?.addEventListener('input', handleRateChange);
		const savedRate = sessionStorage.getItem('rate')
		if (savedRate && rateInput) {
			rateInput.value = savedRate
			handleRateChange()
		}

		pitchInput?.addEventListener('input', handlePitchChange);
		const savedPitch = sessionStorage.getItem('pitch')
		if (savedPitch && pitchInput) {
			pitchInput.value = savedPitch
			handlePitchChange()
		}

		switchVoiceBtn?.addEventListener('click', () => {
			if (voices.length === 0) {
				alert("Vozes não reconhecidas.")
				return
			} else if (voices.length === 1) {
				alert(`Apenas uma voz disponível: ${voices[0].name}`);
				return
			}

			currentVoiceIndex = (currentVoiceIndex + 1) % voices.length;
			const currentVoice = voices[currentVoiceIndex];
			sessionStorage.setItem('voice', currentVoiceIndex + '')

			if (isPlaying || isPaused) {
				synth.cancel();
				speakBlock(currentIndex);
			}

			alert(`Voz atual (${currentVoiceIndex + 1}/${voices.length}): ${currentVoice.name}`);
		})

		// Stop if user navigates away (SPA)
		document.addEventListener('astro:before-swap', stop);
		window.addEventListener('beforeunload', stop);
	})();
</script>