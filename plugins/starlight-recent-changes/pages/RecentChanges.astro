---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import RecentChangesList from "../components/RecentChangesList.astro";
import { getRecentChanges } from "../libs/getRecentChanges.ts";
import { getRepoBaseUrl } from "../libs/repo";

const entries = await getRecentChanges();
const repoBaseUrl = getRepoBaseUrl();
---

<StarlightPage
	frontmatter={{ title: Astro.locals.t("starlight-recent-changes.title") }}
>
	<a href={repoBaseUrl + "/commits/main"} target="_blank" rel="noopener noreferrer">
		Ver todas as mudanças no GitHub
	</a>
	<RecentChangesList entries={entries} />
</StarlightPage>
